---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { pageSummaries } from '../content/site';
import { t } from '../content/i18n';
---

<BaseLayout title="Tools">
  <main class="main">
    <PageHeader {...pageSummaries.tools} />
    <section class="placeholder-panel">
      <h2 data-i18n="panel.tools.title">{t('panel.tools.title')}</h2>
      <p data-i18n="panel.tools.description">{t('panel.tools.description')}</p>
    </section>
  </main>
</BaseLayout>
