---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { pageSummaries } from '../../content/site';
import { t } from '../../content/i18n';
---

<BaseLayout title="System Article">
  <main class="main">
    <PageHeader {...pageSummaries.system} />
    <section class="placeholder-panel">
      <h2 data-i18n="panel.system.title">{t('panel.system.title')}</h2>
      <p data-i18n="panel.system.description">{t('panel.system.description')}</p>
      <span class="coming-soon" data-i18n="common.comingSoon">{t('common.comingSoon')}</span>
    </section>
  </main>
</BaseLayout>
