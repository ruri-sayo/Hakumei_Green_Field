---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { pageSummaries } from '../../content/site';
import { t } from '../../content/i18n';
---

<BaseLayout title="Human Article">
  <main class="main">
    <PageHeader {...pageSummaries.human} />
    <section class="placeholder-panel">
      <h2 data-i18n="panel.human.title">{t('panel.human.title')}</h2>
      <p data-i18n="panel.human.description">{t('panel.human.description')}</p>
    </section>
  </main>
</BaseLayout>
