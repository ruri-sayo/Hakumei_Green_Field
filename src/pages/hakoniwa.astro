---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { pageSummaries } from '../content/site';
import { t } from '../content/i18n';
---

<BaseLayout title="Hakoniwa">
  <main class="main">
    <PageHeader {...pageSummaries.hakoniwa} />
    <div class="placeholder-grid">
      <section class="placeholder-panel">
        <h2 data-i18n="panel.hakoniwa.overview.title">{t('panel.hakoniwa.overview.title')}</h2>
        <p data-i18n="panel.hakoniwa.overview.description">{t('panel.hakoniwa.overview.description')}</p>
      </section>
      <section class="placeholder-panel">
        <h2 data-i18n="panel.hakoniwa.log.title">{t('panel.hakoniwa.log.title')}</h2>
        <p data-i18n="panel.hakoniwa.log.description">{t('panel.hakoniwa.log.description')}</p>
      </section>
      <section class="placeholder-panel">
        <h2 data-i18n="panel.hakoniwa.diary.title">{t('panel.hakoniwa.diary.title')}</h2>
        <p data-i18n="panel.hakoniwa.diary.description">{t('panel.hakoniwa.diary.description')}</p>
      </section>
    </div>
  </main>
</BaseLayout>
