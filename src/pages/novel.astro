---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { pageSummaries } from '../content/site';
import { t } from '../content/i18n';
---

<BaseLayout title="Novel">
  <main class="main">
    <PageHeader {...pageSummaries.novel} />
    <section class="placeholder-panel">
      <h2 data-i18n="panel.novel.title">{t('panel.novel.title')}</h2>
      <p data-i18n="panel.novel.description">{t('panel.novel.description')}</p>
      <span class="coming-soon" data-i18n="common.comingSoon">{t('common.comingSoon')}</span>
    </section>
  </main>
</BaseLayout>
