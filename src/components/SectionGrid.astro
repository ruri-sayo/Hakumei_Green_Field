---
import Icon from './Icon.astro';
import SectionCard from './SectionCard.astro';
import { sectionItems } from '../content/site';
import { t } from '../content/i18n';
---

<section aria-labelledby="contents-title">
  <div class="section-heading">
    <span class="heading-mark"><Icon name="box" size={21} /></span>
    <h2 id="contents-title" data-i18n="heading.contents">{t('heading.contents')}</h2>
  </div>
  <div class="section-grid">
    {sectionItems.map((item) => <SectionCard {...item} />)}
  </div>
</section>

<style>
  .section-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  @media (max-width: 900px) {
    .section-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .section-grid {
      width: 100%;
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>
