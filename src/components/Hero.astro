---
import Icon from './Icon.astro';
import { latestItems } from '../content/site';
import { t } from '../content/i18n';
---

<section class="latest-section" aria-labelledby="latest-title">
  <div class="section-heading">
    <span class="heading-mark"><Icon name="newspaper" size={21} /></span>
    <h2 id="latest-title" data-i18n="heading.latest">{t('heading.latest')}</h2>
  </div>
  <div class="latest-list">
    {latestItems.map((item) => (
      <a class="latest-item" href={item.href}>
        <span class="latest-meta">
          <time>{item.date}</time>
          <span class={`badge badge-${item.category.toLowerCase()}`}>{item.category}</span>
        </span>
        <span class="latest-title" data-i18n-values={JSON.stringify(item.title)}>{item.titleText}</span>
        <Icon name="chevron" size={20} />
      </a>
    ))}
  </div>
</section>

<style>
  .latest-section {
    margin-bottom: 44px;
  }

  .latest-list {
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
    box-shadow: 0 10px 28px rgba(31, 41, 55, 0.06);
  }

  .latest-item {
    display: grid;
    grid-template-columns: 210px minmax(0, 1fr) 28px;
    align-items: center;
    gap: 18px;
    border-bottom: 1px solid #edf2f7;
    padding: 15px 18px;
    transition:
      background 0.2s ease,
      color 0.2s ease;
  }

  .latest-item:last-child {
    border-bottom: 0;
  }

  .latest-item:hover {
    background: #f7faff;
    color: var(--site-blue);
  }

  .latest-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--muted);
    font-family: ui-monospace, "SFMono-Regular", Consolas, monospace;
    font-size: 0.8rem;
  }

  .latest-title {
    overflow: hidden;
    color: inherit;
    font-weight: 700;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .badge {
    border-radius: 5px;
    padding: 1px 8px;
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .badge-news {
    background: #dbeafe;
    color: #1d4ed8;
  }

  .badge-human {
    background: #1f2937;
    color: #fff;
  }

  .badge-system {
    background: #d1fae5;
    color: #047857;
  }

  @media (max-width: 720px) {
    .latest-item {
      grid-template-columns: minmax(0, 1fr) 24px;
      gap: 8px;
    }

    .latest-meta,
    .latest-title {
      grid-column: 1;
    }

    .latest-item svg {
      grid-column: 2;
      grid-row: 1 / span 2;
    }
  }
</style>
