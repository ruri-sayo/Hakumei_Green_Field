---
import { navLinks, site } from '../content/site';
import { t } from '../content/i18n';
---

<footer class="site-footer">
  <div class="footer-inner">
    <div>
      <div class="footer-brand" data-i18n="site.name">{site.name}</div>
      <p data-i18n="footer.tagline">{t('footer.tagline')}</p>
    </div>
    <nav aria-label="Footer navigation">
      {navLinks.map((link) => <a href={link.href} data-i18n={link.key}>{link.label}</a>)}
    </nav>
  </div>
  <p class="copyright">
    &copy; {new Date().getFullYear()}
    <span data-i18n="site.name">{site.name}</span>
    <span data-i18n="footer.copyrightSuffix">{t('footer.copyrightSuffix')}</span>
  </p>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    background: var(--site-blue);
    color: #fff;
  }

  .footer-inner {
    display: flex;
    width: min(1120px, calc(100% - 32px));
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin: 0 auto;
    padding: 32px 0 24px;
  }

  .footer-brand {
    margin-bottom: 4px;
    font-size: 1.2rem;
    font-weight: 800;
  }

  p {
    margin: 0;
    color: #c9d8f3;
    font-size: 0.82rem;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 10px 22px;
  }

  nav a {
    color: #d7e5ff;
    font-size: 0.9rem;
    font-weight: 700;
  }

  nav a:hover {
    color: #fff;
  }

  .copyright {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    padding: 18px 0 24px;
    text-align: center;
  }

  @media (max-width: 760px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }

    nav {
      justify-content: center;
    }
  }
</style>
